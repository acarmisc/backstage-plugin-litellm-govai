{
  "name": "@acarmisc/backstage-plugin-litellm-backend",
  "version": "0.1.16",
  "description": "The Backstage backend plugin for LiteLLM governance",
  "backstage": {
    "role": "backend-plugin",
    "pluginId": "litellm",
    "pluginPackages": [
      "@acarmisc/backstage-plugin-litellm-backend"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "exports": {
    ".": "./dist/index.cjs.js"
  },
  "main": "dist/index.cjs.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "config.d.ts"
  ],
  "scripts": {
    "build": "echo 'Build dist/ from Backstage monorepo: backstage-cli package build'",
    "prepack": "echo 'Dist files must be built in Backstage monorepo and copied here'",
    "postpack": ""
  },
  "dependencies": {
    "@backstage/backend-plugin-api": "^1.0.1",
    "@backstage/catalog-client": "^1.6.0",
    "@backstage/catalog-model": "^1.5.0",
    "@backstage/config": "^1.2.0",
    "@backstage/types": "^1.1.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@backstage/cli": "^0.28.0",
    "@types/express": "^4.17.25",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3"
  },
  "configSchema": "config.d.ts"
}
